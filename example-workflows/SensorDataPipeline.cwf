                "id": "com.continuum.base.node.RestNodeModel",
                "description": "Makes HTTP requests for each row using FreeMarker templated URLs and payloads",
                "title": "REST Client",
                "subTitle": "Send Alert Notifications",
                "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" stroke=\"currentColor\" strokeWidth={1.5} viewBox=\"0 0 24 24\">\n    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418\" />\n</svg>",
                "nodeModel": "com.continuum.base.node.RestNodeModel",
                "busy": null,
                "inputs": {
                    "data": {
                        "name": "input table",
                        "contentType": "text/plain"
                    }
                },
                "outputs": {
                    "data": {
                        "name": "table with responses",
                        "contentType": "text/plain"
                    }
                },
                "properties": {
                    "method": "POST",
                    "url": "https://posthook-api.mock.beeceptor.com/v1/hooks",
                    "payload": "{\n  \"severity\": \"critical\",\n  \"machine_id\": \"${row.machine_id}\",\n  \"sensor_type\": \"${row.sensor_type}\",\n  \"value\": ${row.value},\n  \"is_anomaly\": ${row.is_anomaly?string(\"true\", \"false\")},\n  \"batch_id\": ${row.batch_id},\n  \"timestamp\": \"${row.timestamp}\",\n  \"message\": \"Critical reading detected on ${row.machine_id}: ${row.sensor_type} = ${row.value}\"\n}"
                },
