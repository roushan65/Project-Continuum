            "data": {
                "id": "com.continuum.base.node.CreateTableNodeModel",
                "description": "Creates a structured table from FreeMarker template configuration",
                "title": "Create Table",
                "subTitle": "IoT Sensor Readings",
                "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" stroke=\"currentColor\" strokeWidth={1.5} viewBox=\"0 0 24 24\">\n\t<path d=\"M21.5 2h-19a.5.5 0 0 0-.5.5v19a.5.5 0 0 0 .5.5h19a.5.5 0 0 0 .5-.5v-19a.5.5 0 0 0-.5-.5zm-13 19H3v-5.5h5.5V21zm0-6.5H3v-5h5.5v5zm0-6H3V3h5.5v5.5zm6 12.5h-5v-5.5h5V21zm0-6.5h-5v-5h5v5zm0-6h-5V3h5v5.5zM21 21h-5.5v-5.5H21V21zm0-6.5h-5.5v-5H21v5zm0-6h-5.5V3H21v5.5z\" fill=\"currentColor\"/>\n</svg>",
                "nodeModel": "com.continuum.base.node.CreateTableNodeModel",
                "busy": null,
                "inputs": null,
                "outputs": {
                    "data": {
                        "name": "output table",
                        "contentType": "text/plain"
                    }
                },
                "properties": {
                    "jsonArrayString": "[\n<#-- Simulate IoT sensor readings from a manufacturing plant -->\n<#-- Sensors: Temperature, Pressure, Vibration across 5 machines -->\n<#list 1..500 as i>\n  <#assign machineId = (i % 5) + 1>\n  <#assign sensorType = [\"temperature\", \"pressure\", \"vibration\"][i % 3]>\n  <#-- Base values per sensor type -->\n  <#assign baseValue = {\"temperature\": 75, \"pressure\": 100, \"vibration\": 50}[sensorType]>\n  <#-- Add normal variation -->\n  <#assign normalVariation = (i % 7) - 3>\n  <#-- Inject anomalies: every 25th reading has extreme values -->\n  <#if i % 25 == 0>\n    <#assign value = baseValue + ((i % 2 == 0)?then(45, -35))>\n    <#assign status = \"critical\">\n  <#elseif i % 50 == 7>\n    <#assign value = baseValue + 25>\n    <#assign status = \"warning\">\n  <#else>\n    <#assign value = baseValue + normalVariation>\n    <#assign status = \"normal\">\n  </#if>\n{\"reading_id\": ${i}, \"machine_id\": \"M${machineId}\", \"sensor_type\": \"${sensorType}\", \"value\": ${value}, \"status\": \"${status}\", \"timestamp\": \"2026-02-28T${(8 + (i % 12))?string(\"00\")}:${(i % 60)?string(\"00\")}:00Z\"}<#if i_has_next>,</#if>\n</#list>\n]"
                },
                "propertiesSchema": {
                    "type": "object",
                    "properties": {
                        "jsonArrayString": {
                            "type": "string",
                            "title": "JSON Array",
                            "description": "JSON array string where each object becomes a table row"
                        }
                    },
                    "required": [
                        "jsonArrayString"
                    ]
                },
                "propertiesUISchema": {
                    "type": "VerticalLayout",
                    "elements": [
                        {
                            "type": "Control",
                            "scope": "#/properties/jsonArrayString",
                            "options": {
                                "format": "code",
                                "language": "freemarker",
                                "rows": 15
                            }
                        }
                    ]
                },
                "status": null,
                "nodeProgress": null
            },
            "width": 224,
            "height": 100
        },
