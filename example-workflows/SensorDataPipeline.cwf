            "data": {
                "id": "com.continuum.base.node.AnomalyDetectorZScoreNodeModel",
                "description": "Detects outliers using Z-score method (flags values with |Z| > 2)",
                "title": "Anomaly Detector",
                "subTitle": "Z-Score Analysis",
                "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" stroke=\"currentColor\" strokeWidth={1.5} viewBox=\"0 0 24 24\">\n    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6\" />\n</svg>",
                "nodeModel": "com.continuum.base.node.AnomalyDetectorZScoreNodeModel",
                "busy": null,
                "inputs": {
                    "data": {
                        "name": "input table",
                        "contentType": "text/plain"
                    }
                },
                "outputs": {
                    "data": {
                        "name": "table with outlier flags",
                        "contentType": "text/plain"
                    }
                },
                "properties": {
                    "valueCol": "value",
                    "zThreshold": 2.5,
                    "outputColumnName": "is_anomaly"
                },
                "propertiesSchema": {
                    "type": "object",
                    "properties": {
                        "valueCol": {
                            "type": "string",
                            "title": "Value Column",
                            "description": "The numeric column to analyze for outliers"
                        },
                        "zThreshold": {
                            "type": "number",
                            "title": "Z-Score Threshold",
                            "description": "Threshold for outlier detection (values with |Z| > threshold are flagged)",
                            "default": 2,
                            "minimum": 0.1,
                            "maximum": 5
                        },
                        "outputColumnName": {
                            "type": "string",
                            "title": "Output Column Name",
                            "description": "Name of the column to add with outlier flags",
                            "default": "is_outlier"
                        }
                    },
